rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default deny all incoming requests
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable Global Secutity Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Profile Entity Rules ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'phoneNumber', 'address', 'city', 'createdAt'])
        && data.uid is string && data.uid == request.auth.uid
        && data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 150
        && data.phoneNumber is string && data.phoneNumber.size() >= 8 && data.phoneNumber.size() <= 30
        && data.address is string && data.address.size() >= 10 && data.address.size() <= 500
        && data.city is string && data.city.size() >= 2 && data.city.size() <= 50;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }

    // --- Customer Order Entity Rules ---
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'customerName', 'customerPhone', 'customerAddress', 'customerCity', 'items', 'totalAmount', 'userId'])
        && data.id is string && data.id.size() >= 5 && data.id.size() <= 50
        && data.customerName is string && data.customerName.size() >= 2 && data.customerName.size() <= 150
        && data.customerPhone is string && data.customerPhone.size() >= 8 && data.customerPhone.size() <= 35
        && data.customerAddress is string && data.customerAddress.size() >= 10 && data.customerAddress.size() <= 500
        && data.customerCity is string && data.customerCity.size() >= 2 && data.customerCity.size() <= 55
        && data.items is list && data.items.size() > 0 && data.items.size() <= 100
        && data.totalAmount is number && data.totalAmount >= 0
        && data.userId is string && data.userId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidOrder(request.resource.data);
      allow update, delete: if false;
    }
  }
}
