rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default deny all incoming requests
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable Global Security Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Profile Entity Rules ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) 
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.fullName is string
        && request.resource.data.phoneNumber is string;
      allow delete: if false;
    }

    // --- Customer Order Entity Rules ---
    match /orders/{orderId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.id is string
        && request.resource.data.customerName is string
        && request.resource.data.customerPhone is string;
      allow update, delete: if false;
    }

    // --- Public read support for categories, configurations and products ---
    match /products/{prodId} {
      allow read: if true;
    }
    match /categories/{catId} {
      allow read: if true;
    }
    match /config/{configId} {
      allow read: if true;
    }
  }
}
